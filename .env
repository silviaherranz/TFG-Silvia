# ─────────────────────────────────────────────
# RT-ModelCard — environment variables template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# ── MySQL ──────────────────────────────────────
MYSQL_ROOT_PASSWORD=root_secret
MYSQL_DATABASE=rtmc
MYSQL_USER=rtmc
MYSQL_PASSWORD=rtmc_pass

# ── FastAPI backend ───────────────────────────
# Full async DSN — must match MySQL credentials above
DATABASE_URL=mysql+aiomysql://rtmc:rtmc_pass@db:3306/rtmc

# Random secret used for token signing (generate with: openssl rand -hex 32)
SECRET_KEY=change_me_in_production

# Set to false in production
DEBUG=true

# Comma-separated list of allowed CORS origins (Streamlit default: 8501)
CORS_ORIGINS=["http://localhost:8501"]

API_PORT=8000
