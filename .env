# ─────────────────────────────────────────────
# RT-ModelCard — environment variables template
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
# ─────────────────────────────────────────────

# ── MySQL ──────────────────────────────────────
MYSQL_ROOT_PASSWORD=root_secret
MYSQL_DATABASE=rtmc
MYSQL_USER=rtmc
MYSQL_PASSWORD=rtmc_pass

# ── FastAPI backend ───────────────────────────
# Full async DSN — must match MySQL credentials above
DATABASE_URL=mysql+aiomysql://rtmc:rtmc_pass@db:3306/rtmc

# Random secret used for token signing (generate with: openssl rand -hex 32)
SECRET_KEY=change_me_in_production

# Set to false in production
DEBUG=true

# Comma-separated list of allowed CORS origins (Streamlit default: 8501)
CORS_ORIGINS=["http://localhost:8501"]

API_PORT=8000

# ── Password reset ────────────────────────────────────────────────────────────
# Base URL of the Streamlit frontend — used to build the reset link in emails.
FRONTEND_BASE_URL=http://localhost:8501

# How long a reset token remains valid (minutes). Default: 60.
PASSWORD_RESET_EXPIRE_MINUTES=60

# ── SMTP / email ──────────────────────────────────────────────────────────────
# Leave SMTP_HOST empty to disable email sending.
# When DEBUG=true and SMTP_HOST is empty, the reset URL is printed to the
# backend log so you can test the flow locally without a mail server.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
# SMTP_USE_TLS=true → implicit TLS on connect (port 465, e.g. Gmail SSL).
SMTP_USE_TLS=false
# SMTP_START_TLS=true → upgrade via STARTTLS after connect (port 587).
SMTP_START_TLS=true
# Sender address shown in the From: header.
EMAIL_FROM=noreply@rt-modelcard.local
